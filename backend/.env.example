# Database Configuration
# Required: Connection string for PostgreSQL database
# LOCAL: postgresql://user:password@localhost:5432/portfolio_db
# RENDER: postgresql://user:password@host:5432/database_name
DATABASE_URL=postgresql://user:password@localhost:5432/portfolio_db

# JWT Configuration
# IMPORTANT: Generate a NEW SECRET_KEY for production using:
# python3 -c "import secrets; print(secrets.token_hex(32))"
# Never use the same key across environments
SECRET_KEY=your-super-secret-key-here-generate-with-python-secrets

# CORS Origins (Comma-separated list of allowed frontend domains)
# Development: http://localhost:5173
# Production GitHub Pages: https://toby-sym.github.io
# Production Custom Domain: https://yourdomain.com
# Format: ["http://localhost:5173","https://example.com"]
CORS_ORIGINS=["http://localhost:5173"]

# Admin Credentials
# IMPORTANT: Change ADMIN_PASSWORD immediately after first deployment!
# After changing password in .env, restart the service and re-initialize with POST /init
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# Server Configuration
# PORT: Server port (typically 8000 for local dev, dynamically assigned by Render in production)
PORT=8000
